<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Opening Hours - Regular Schedule
         ============================================================ -->

    <record id="view_opening_hours_tree" model="ir.ui.view">
        <field name="name">opening.hours.tree</field>
        <field name="model">opening.hours</field>
        <field name="arch" type="xml">
            <list editable="bottom" default_order="day_of_week">
                <field name="day_of_week"/>
                <field name="is_open"/>
                <field name="open_time" widget="float_time" invisible="not is_open"/>
                <field name="close_time" widget="float_time" invisible="not is_open"/>
            </list>
        </field>
    </record>

    <record id="action_opening_hours" model="ir.actions.act_window">
        <field name="name">Otevírací doba</field>
        <field name="res_model">opening.hours</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_opening_hours_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Nastavte otevírací dobu pro každý den v týdnu
            </p>
        </field>
    </record>

    <!-- ============================================================
         Opening Hours - Overrides (holidays, special days)
         ============================================================ -->

    <record id="view_opening_hours_override_tree" model="ir.ui.view">
        <field name="name">opening.hours.override.tree</field>
        <field name="model">opening.hours.override</field>
        <field name="arch" type="xml">
            <list editable="bottom" default_order="date">
                <field name="date"/>
                <field name="is_open"/>
                <field name="open_time" widget="float_time" invisible="not is_open"/>
                <field name="close_time" widget="float_time" invisible="not is_open"/>
                <field name="reason"/>
            </list>
        </field>
    </record>

    <record id="view_opening_hours_override_calendar" model="ir.ui.view">
        <field name="name">opening.hours.override.calendar</field>
        <field name="model">opening.hours.override</field>
        <field name="arch" type="xml">
            <calendar date_start="date" date_stop="date" color="is_open" mode="month" quick_create="0">
                <field name="reason"/>
                <field name="is_open"/>
            </calendar>
        </field>
    </record>

    <record id="view_opening_hours_override_form" model="ir.ui.view">
        <field name="name">opening.hours.override.form</field>
        <field name="model">opening.hours.override</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="is_open"/>
                            <field name="reason"/>
                        </group>
                        <group>
                            <field name="open_time" widget="float_time" invisible="not is_open"/>
                            <field name="close_time" widget="float_time" invisible="not is_open"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_opening_hours_override" model="ir.actions.act_window">
        <field name="name">Výjimky otevírací doby</field>
        <field name="res_model">opening.hours.override</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Přidejte výjimky pro svátky a speciální dny
            </p>
        </field>
    </record>

    <!-- ============================================================
         HA Status
         ============================================================ -->

    <record id="view_opening_hours_status_form" model="ir.ui.view">
        <field name="name">opening.hours.status.form</field>
        <field name="model">opening.hours.status</field>
        <field name="arch" type="xml">
            <form create="0" delete="0" duplicate="0">
                <sheet>
                    <group>
                        <group string="Stav z Home Assistant">
                            <field name="ha_is_open"/>
                            <field name="last_update"/>
                        </group>
                        <group string="Nastavení">
                            <field name="webhook_secret" password="True"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>Webhook URL:</strong>
                        <code>/opening-hours/webhook</code>
                        <br/>
                        Home Assistant posílá POST JSON s
                        <code>{"secret": "...", "is_open": true/false}</code>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_opening_hours_status" model="ir.actions.act_window">
        <field name="name">Stav obchůdku (HA)</field>
        <field name="res_model">opening.hours.status</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_opening_hours_status_form"/>
        <field name="res_id" ref="opening_hours_status_default"/>
        <field name="target">inline</field>
    </record>

</odoo>
